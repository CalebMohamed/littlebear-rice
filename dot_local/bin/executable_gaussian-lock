#!/bin/sh
# Load colors generated by wallust
. "$HOME/.cache/swaylock/colors.sh"

# This is a bit spenny so switching to just current background:
IMAGE="$HOME/.local/share/current_wallpaper.jpg"

# Define temporary image path
# IMAGE=/tmp/screen_lock.png

# # screenshot with grim and slurp
# grim -t png "$IMAGE" && \
# # magick gaussian blur
# magick "$IMAGE" -filter Gaussian -blur 0x8 "$IMAGE" && \
# wlock with the blurred image
swaylock -f -i "$IMAGE" \
	--font "CaskaydiaCove NFM" \
	--font-size 16 \
	--text-color "$TEXT" \
	--text-wrong-color "$TEXT" \
	--text-clear-color "$TEXT" \
	--text-caps-lock-color "$TEXT" \
	--inside-color "$INSIDE" \
	--inside-ver-color "$INSIDE_VER" \
	--inside-wrong-color "$INSIDE_WRONG" \
	--inside-clear-color "$INSIDE_CLEAR" \
	--ring-color "$RING" \
	--ring-ver-color "$RING_VER" \
	--ring-wrong-color "$RING_WRONG" \
	--separator-color "$RING" \
	--key-hl-color "$KEY" \
	--bs-hl-color "$BACKSPACE" \
	-r
