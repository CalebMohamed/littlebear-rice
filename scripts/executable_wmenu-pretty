#!/bin/sh
# Load colors generated by wallust
. "$HOME/.cache/wmenu/colors.sh"

# Determine if running wmenu or wmenu-run based on symlink/argument
COMMAND="wmenu"
if [ "$1" = "--run" ]; then
    COMMAND="wmenu-run"
    shift
fi

# Execute with forwarded arguments and colors
# Standard input is inherited automatically
exec "$COMMAND" -N "$NB" -n "$NF" -M "$PB" -m "$PF" -S "$SB" -s "$SF" -f "$FONT" "$@"
